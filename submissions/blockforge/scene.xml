<mujoco model="handiforge">
  <include file="panda.xml"/>

  <compiler angle="radian"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <global azimuth="140" elevation="-25" offwidth="640" offheight="480"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.2 0.3 0.5" rgb2="0.05 0.05 0.1" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.25 0.28 0.35" rgb2="0.18 0.20 0.25" markrgb="0.4 0.4 0.5" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="6 6" reflectance="0.15"/>

    <material name="table_surface" rgba="0.55 0.45 0.35 1"/>
    <material name="table_leg" rgba="0.4 0.3 0.2 1"/>
    <material name="wall" rgba="0.45 0.45 0.5 1"/>

    <material name="cube_red" rgba="0.95 0.2 0.2 1"/>
    <material name="cube_blue" rgba="0.2 0.4 0.95 1"/>
    <material name="cube_green" rgba="0.2 0.85 0.3 1"/>
    <material name="cube_yellow" rgba="0.95 0.85 0.15 1"/>

    <material name="zone_red" rgba="0.95 0.2 0.2 0.35"/>
    <material name="zone_blue" rgba="0.2 0.4 0.95 0.35"/>
    <material name="zone_green" rgba="0.2 0.85 0.3 0.35"/>
    <material name="zone_yellow" rgba="0.95 0.85 0.15 0.35"/>
  </asset>

  <worldbody>
    <light name="key" pos="2 0 2.5" dir="-0.5 0 -1" directional="false"
      diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3"/>
    <light name="fill" pos="-1 2 1.5" dir="0.5 -1 -0.5" directional="false"
      diffuse="0.4 0.4 0.5" specular="0 0 0"/>
    <geom name="floor" size="0 0 0.025" type="plane" material="groundplane"/>

    <!-- Table -->
    <body name="table" pos="0.5 0 0">
      <geom name="table_top" type="box" size="0.45 0.3 0.02" pos="0 0 0.50" material="table_surface"/>
      <geom name="leg_fl" type="cylinder" size="0.02 0.25" pos="-0.35 -0.22 0.25" material="table_leg"/>
      <geom name="leg_fr" type="cylinder" size="0.02 0.25" pos="0.35 -0.22 0.25" material="table_leg"/>
      <geom name="leg_bl" type="cylinder" size="0.02 0.25" pos="-0.35 0.22 0.25" material="table_leg"/>
      <geom name="leg_br" type="cylinder" size="0.02 0.25" pos="0.35 0.22 0.25" material="table_leg"/>

      <site name="target_red" type="box" size="0.035 0.035 0.002" pos="-0.15 -0.08 0.52" rgba="0.95 0.2 0.2 0.5"/>
      <site name="target_blue" type="box" size="0.035 0.035 0.002" pos="0.15 -0.08 0.52" rgba="0.2 0.4 0.95 0.5"/>
      <site name="target_green" type="box" size="0.035 0.035 0.002" pos="-0.15 0.08 0.52" rgba="0.2 0.85 0.3 0.5"/>
      <site name="target_yellow" type="box" size="0.035 0.035 0.002" pos="0.15 0.08 0.52" rgba="0.95 0.85 0.15 0.5"/>

      <site name="stage_red" type="box" size="0.03 0.03 0.002" pos="-0.3 0 0.53" rgba="0.95 0.2 0.2 0.3"/>
      <site name="stage_blue" type="box" size="0.03 0.03 0.002" pos="-0.15 0 0.53" rgba="0.2 0.4 0.95 0.3"/>
      <site name="stage_green" type="box" size="0.03 0.03 0.002" pos="0.0 0 0.53" rgba="0.2 0.85 0.3 0.3"/>
      <site name="stage_yellow" type="box" size="0.03 0.03 0.002" pos="0.15 0 0.53" rgba="0.95 0.85 0.15 0.3"/>
    </body>

    <!-- Free-floating cubes -->
    <body name="cube_red" pos="0.2 0 0.58">
      <freejoint/>
      <geom name="cube_red_geom" type="box" size="0.025 0.025 0.025" material="cube_red" mass="0.1"/>
    </body>
    <body name="cube_blue" pos="0.35 0 0.58">
      <freejoint/>
      <geom name="cube_blue_geom" type="box" size="0.025 0.025 0.025" material="cube_blue" mass="0.1"/>
    </body>
    <body name="cube_green" pos="0.5 0 0.58">
      <freejoint/>
      <geom name="cube_green_geom" type="box" size="0.025 0.025 0.025" material="cube_green" mass="0.1"/>
    </body>
    <body name="cube_yellow" pos="0.65 0 0.58">
      <freejoint/>
      <geom name="cube_yellow_geom" type="box" size="0.025 0.025 0.025" material="cube_yellow" mass="0.1"/>
    </body>

    <!-- Containment walls -->
    <geom name="wall_right" type="box" size="0.02 0.3 0.12" pos="0.95 0 0.55" material="wall"/>
    <!-- BACK WALL REMOVED — this is the Pit of Death where cubes fall. Necromancer hunts them down. -->

    <camera name="overhead" pos="0.45 -0.1 1.0" xyaxes="1 0 0 0 1 0" mode="fixed"/>
    <camera name="front" pos="0.45 -0.8 0.7" xyaxes="1 0 0 0 0.4 0.916" mode="fixed"/>
    <camera name="side" pos="1.1 0 0.65" xyaxes="0 1 0 -0.5 0 0.866" mode="fixed"/>
    <camera name="closeup" pos="0.45 -0.3 0.72" xyaxes="1 0 0 0 0.6 0.8" mode="fixed"/>
  </worldbody>

  <sensor>
    <framepos name="cube_red_pos" objtype="body" objname="cube_red"/>
    <framepos name="cube_blue_pos" objtype="body" objname="cube_blue"/>
    <framepos name="cube_green_pos" objtype="body" objname="cube_green"/>
    <framepos name="cube_yellow_pos" objtype="body" objname="cube_yellow"/>
  </sensor>
</mujoco>
